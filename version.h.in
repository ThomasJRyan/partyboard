#ifndef VERSION_H
#define VERSION_H

#define PARTY_BOARD_WC_DESCRIBE "@PARTY_BOARD_WC_DESCRIBE@"
#define PARTY_BOARD_VERSION_STRING "@PARTY_BOARD_VERSION_STRING@"

#define PARTY_BOARD_WC_BRANCH "@PARTY_BOARD_WC_BRANCH@"
#define PARTY_BOARD_WC_REVISION "@PARTY_BOARD_WC_REVISION@"
#define PARTY_BOARD_WC_DATE "@PARTY_BOARD_WC_DATE@"
#define PARTY_BOARD_BUILD_TYPE "@CMAKE_BUILD_TYPE@"

#if defined(__x86_64__) || defined(_M_AMD64)
#define PARTY_BOARD_ARCH "x86_64"
#elif defined(__i386__) || defined(_M_IX86)
#define PARTY_BOARD_ARCH "x86"
#elif defined(__aarch64__) || defined(_M_ARM64)
#define PARTY_BOARD_ARCH "arm64"
#endif

#define PARTY_BOARD_PLATFORM_NAME "@PLATFORM_NAME@"
#define PARTY_BOARD_DLPACKAGE "partyboard-@PARTY_BOARD_WC_DESCRIBE@-" PARTY_BOARD_PLATFORM_NAME "-" PARTY_BOARD_ARCH

#define PARTY_BOARD_SENTRY_DSN "@PARTY_BOARD_SENTRY_DSN@"
#define PARTY_BOARD_SENTRY_ENVIRONMENT "@PARTY_BOARD_SENTRY_ENVIRONMENT@"

#endif
