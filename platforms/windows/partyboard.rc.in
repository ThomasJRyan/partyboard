#include <windows.h>
#include <winver.h>

IDI_MAIN_ICON ICON "@PARTY_BOARD_WINDOWS_ICON_ICO@"
1 RT_MANIFEST "@PARTY_BOARD_WINDOWS_MANIFEST@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@PROJECT_VERSION_TWEAK@
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@PROJECT_VERSION_TWEAK@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", "@PARTY_BOARD_COMPANY_NAME@\0"
            VALUE "FileDescription", "@PARTY_BOARD_FILE_DESCRIPTION@\0"
            VALUE "FileVersion", "@PARTY_BOARD_VERSION_STRING@\0"
            VALUE "InternalName", "partyboard\0"
            VALUE "LegalCopyright", "@PARTY_BOARD_COPYRIGHT@\0"
            VALUE "OriginalFilename", "partyboard.exe\0"
            VALUE "ProductName", "@PARTY_BOARD_PRODUCT_NAME@\0"
            VALUE "ProductVersion", "@PARTY_BOARD_VERSION_STRING@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
